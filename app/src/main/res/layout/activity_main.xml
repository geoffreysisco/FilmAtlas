<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        tools:context=".MainActivity">

        <!-- Top app bar (search pill is a toolbar child for full-width layout) -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/top_app_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:minHeight="?attr/actionBarSize"
            app:contentInsetEnd="0dp"
            app:contentInsetEndWithActions="16dp"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:logo="@null"
            app:navigationIcon="@null"
            app:title="">

            <!-- Search pill -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/search_action_root"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#CAC4D0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <EditText
                        android:id="@+id/search_action_input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:autofillHints="search"
                        android:background="@null"
                        android:hint="@string/search_movie_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/search_action_clear"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="@string/clear_search"
                        android:src="@drawable/ic_close_24"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </com.google.android.material.appbar.MaterialToolbar>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/search_suggestions_list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxHeight="260dp"
            android:visibility="gone"
            android:elevation="12dp"
            android:clickable="true"
            android:focusable="true"
            android:overScrollMode="never"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_suggestions_panel"
            app:layout_constraintTop_toBottomOf="@id/top_app_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible" />

        <!-- Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/mode_tabs"
            style="@style/Widget.FilmAtlas.TabLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/top_app_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorFullWidth="false" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_tabs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="@dimen/tabs_divider_inset"
            android:layout_marginEnd="@dimen/tabs_divider_inset"
            app:dividerColor="?attr/colorOutlineVariant"
            app:layout_constraintTop_toBottomOf="@id/mode_tabs"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/main_tabs"
            style="@style/Widget.FilmAtlas.TabLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/divider_tabs"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorFullWidth="false" />

        <!-- Movie grid (swipe-to-refresh removed) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/content_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/main_tabs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/empty_state_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/empty_search_results"
                android:textSize="16sp"
                android:visibility="gone"
                android:maxLines="3"
                android:ellipsize="end"
                app:layout_constraintVertical_bias="0.33"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btn_exit_search"
                app:layout_constraintVertical_chainStyle="packed"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_exit_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back to browse"
                android:visibility="gone"
                android:backgroundTint="@color/md_theme_primary"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/empty_state_text"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible" />

            <!-- Filter empty state (behind bottom sheet) -->
            <TextView
                android:id="@+id/empty_state_filter_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/empty_filter_not_applied"
                android:textSize="16sp"
                android:visibility="gone"
                android:maxLines="4"
                android:ellipsize="end"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                app:layout_constraintVertical_bias="0.33"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btn_open_filter"
                app:layout_constraintVertical_chainStyle="packed"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open filter"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/empty_state_filter_text"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <!-- Overlay container for dialog/details fragment -->
        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/main_tabs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Filter shortcut (only visible when a filter is applied) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_filter_applied"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@string/open_filter"
            android:visibility="gone"
            app:backgroundTint="@color/md_theme_primary"
            app:rippleColor="@color/md_theme_secondary"
            app:srcCompat="@drawable/ic_filter_list_24"
            app:shapeAppearanceOverlay="@style/CircleFab"
            app:tint="@android:color/white"
            app:maxImageSize="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/main_tabs"
            tools:visibility="visible" />

        <!-- Back to top -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_to_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="@string/back_to_top"
            android:visibility="gone"
            app:backgroundTint="@color/md_theme_primary"
            app:fabSize="normal"
            app:rippleColor="@color/md_theme_secondary"
            app:shapeAppearanceOverlay="@style/CircleFab"
            app:srcCompat="@drawable/ic_arrow_up_24"
            app:tint="@android:color/white"
            app:maxImageSize="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible" />

        <!-- Discover refresh (Discover tab only) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_refresh_discover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@string/refresh_discover"
            android:visibility="gone"
            app:backgroundTint="@color/md_theme_primary"
            app:rippleColor="@color/md_theme_secondary"
            app:shapeAppearanceOverlay="@style/CircleFab"
            app:srcCompat="@drawable/ic_refresh_24"
            app:tint="@android:color/white"
            app:maxImageSize="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/main_tabs"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>